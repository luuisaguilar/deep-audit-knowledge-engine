[Unit]
Description=YouTube Analyzer Streamlit Dashboard
After=network.target

[Service]
User=root
WorkingDirectory=/root/youtube-analyzer
ExecStart=/root/youtube-analyzer/venv/bin/streamlit run app.py --server.port 8501 --server.address 0.0.0.0
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
